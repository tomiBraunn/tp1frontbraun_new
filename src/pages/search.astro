---
import Layout from '../components/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { fetchFlights } from '../utils/fetchFlights.js';

let flights = [];
let apiError = false;

try {
  flights = await fetchFlights();
} catch (error) {
  console.error('Flight fetch failed:', error.message);
  apiError = true;
}

const flightsJson = JSON.stringify(flights).replace(/</g, '\u003c');
const allCountries = Array.from(new Set(flights.map((flight) => flight.country).filter(Boolean))).sort();
---

<Layout>
  <Navbar />

  <div class="mx-auto max-w-6xl px-4 py-10 space-y-8">

    <!-- Page header -->
    <div class="space-y-2">
      <span class="inline-flex items-center gap-2 rounded-full border border-indigo-500/20 bg-indigo-500/8 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-indigo-300">
        Búsqueda por país
      </span>
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">Explorar por destino</h1>
      <p class="text-sm text-slate-400">Selecciona un país para ver hasta 20 vuelos activos registrados en esa región.</p>
    </div>

    <!-- Filter -->
    <div class="panel rounded-2xl p-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:gap-6">
        <div class="flex-1 space-y-2">
          <label class="block text-xs font-semibold uppercase tracking-widest text-slate-500" for="countrySelect">
            País
          </label>
          <select
            id="countrySelect"
            class="w-full rounded-xl border border-white/10 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-500/20"
          >
            {allCountries.map((country) => (
              <option value={country}>{country}</option>
            ))}
          </select>
        </div>
        <p class="text-sm text-slate-500 sm:mb-3" id="searchStatus">Selecciona un país para ver resultados</p>
      </div>
    </div>

    <!-- Error / results -->
    {apiError ? (
      <div class="rounded-2xl border border-red-400/20 bg-red-500/10 px-5 py-4 text-sm text-red-300">
        ⚠️ No se pudieron cargar los datos de vuelos. Intenta de nuevo más tarde.
      </div>
    ) : (
      <div>
        <div id="flightsData" data-flights={flightsJson} hidden></div>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" id="flightGrid"></div>
      </div>
    )}
  </div>

  <script is:inline type="module">
    const flights = JSON.parse(document.getElementById('flightsData')?.dataset.flights || '[]');
    const select = document.querySelector('#countrySelect');
    const grid = document.querySelector('#flightGrid');
    const status = document.querySelector('#searchStatus');

    const renderFlights = (list) => {
      if (!grid || !status) return;
      grid.innerHTML = '';
      const showing = list.slice(0, 20);

      if (showing.length === 0) {
        status.textContent = 'No hay vuelos disponibles para este país.';
        return;
      }

      status.textContent = `Mostrando ${showing.length} vuelos para ${select?.value}`;

      showing.forEach((flight) => {
        const card = document.createElement('div');
        card.className = 'flight-card group relative flex flex-col gap-4 rounded-2xl border border-white/10 bg-slate-950/60 p-5 shadow-glow backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-sky-500/30 hover:bg-slate-900/80';

        const accent = document.createElement('div');
        accent.className = 'absolute inset-x-0 top-0 h-0.5 rounded-t-2xl bg-gradient-to-r from-sky-400 via-indigo-400 to-violet-400 opacity-70';
        card.appendChild(accent);

        const header = document.createElement('div');
        header.className = 'flex items-start justify-between gap-3';
        const headerLeft = document.createElement('div');
        const title = document.createElement('h3');
        title.className = 'text-lg font-bold tracking-tight text-white';
        title.textContent = flight.callsign;
        const badge = document.createElement('span');
        badge.className = 'mt-1 inline-flex items-center gap-1 rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-medium text-slate-300';
        badge.innerHTML = `<span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>${flight.country}`;
        headerLeft.appendChild(title);
        headerLeft.appendChild(badge);
        const icon = document.createElement('div');
        icon.className = 'flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-sky-500/10 text-sky-400 text-sm';
        icon.textContent = '✈';
        header.appendChild(headerLeft);
        header.appendChild(icon);
        card.appendChild(header);

        const metrics = document.createElement('div');
        metrics.className = 'grid grid-cols-2 gap-2';
        const speedChip = document.createElement('div');
        speedChip.className = 'metric-chip';
        speedChip.innerHTML = `<p class="text-[10px] font-semibold uppercase tracking-widest text-amber-400/80">Velocidad</p><p class="mt-0.5 text-sm font-bold text-amber-300">${flight.speedKts} kt</p><p class="text-xs text-slate-500">${flight.speedKmh} km/h</p>`;
        const altChip = document.createElement('div');
        altChip.className = 'metric-chip';
        const altM = Math.round(flight.altitude * 0.3048);
        altChip.innerHTML = `<p class="text-[10px] font-semibold uppercase tracking-widest text-sky-400/80">Altitud</p><p class="mt-0.5 text-sm font-bold text-sky-300">${flight.altitude} ft</p><p class="text-xs text-slate-500">${altM} m</p>`;
        metrics.appendChild(speedChip);
        metrics.appendChild(altChip);
        card.appendChild(metrics);

        if (flight.lat && flight.lon) {
          const mapContainer = document.createElement('div');
          mapContainer.className = 'overflow-hidden rounded-xl border border-white/8 h-[160px]';
          const iframe = document.createElement('iframe');
          iframe.className = 'h-full w-full';
          iframe.src = `https://maps.google.com/maps?q=${flight.lat},${flight.lon}&z=4&output=embed`;
          iframe.loading = 'lazy';
          iframe.referrerPolicy = 'no-referrer-when-downgrade';
          iframe.title = 'Flight location';
          mapContainer.appendChild(iframe);
          card.appendChild(mapContainer);

          const link = document.createElement('a');
          link.className = 'flex items-center gap-1.5 text-xs font-medium text-sky-400 transition hover:text-sky-300';
          link.href = `https://www.google.com/maps/search/?api=1&query=${flight.lat},${flight.lon}`;
          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          link.innerHTML = `<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>Abrir en Google Maps`;
          card.appendChild(link);
        } else {
          const noLoc = document.createElement('p');
          noLoc.className = 'text-xs text-slate-500';
          noLoc.textContent = 'Ubicación no disponible';
          card.appendChild(noLoc);
        }

        grid.appendChild(card);
      });
    };

    if (select) {
      const update = () => {
        const country = select.value;
        const filtered = flights.filter((flight) => flight.country === country);
        renderFlights(filtered);
      };
      select.addEventListener('change', update);
      update();
    }
  </script>
</Layout>
