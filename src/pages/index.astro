---
import Layout from "../components/Layout.astro";
import Navbar from "../components/Navbar.astro";
import FlightCard from "../components/FlightCard.astro";
import { fetchFlights } from "../utils/fetchFlights.js";

let flights = [];
let apiError = false;

try {
  flights = await fetchFlights();
} catch (error) {
  console.error("Flight fetch failed:", error.message);
  apiError = true;
}

// Función para obtener n elementos random de un array
const getRandomFlights = (array, n) => {
  const shuffled = [...array].sort(() => Math.random() - 0.5);
  return shuffled.slice(0, n);
};

const randomFlights = getRandomFlights(flights, 20);
---

<Layout>
  <Navbar slot="header" />
  <main class="space-y-8">
    <!-- Hero Section -->
    <section class="relative overflow-hidden rounded-3xl">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-600/20 via-purple-600/20 to-pink-600/20 blur-3xl" />
      <div class="relative rounded-3xl border border-white/10 bg-gradient-to-br from-slate-900/90 via-slate-950/95 to-slate-900/90 p-12">
        <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
          <div class="flex flex-col justify-center space-y-6">
            <div class="space-y-4">
              <div class="inline-flex w-fit rounded-full bg-blue-500/15 px-4 py-2">
                <span class="text-xs font-semibold uppercase tracking-wider text-blue-300">Flight Radar</span>
              </div>
              <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
                Dashboard de vuelos en tiempo real
              </h1>
              <p class="text-lg text-slate-400">
                Explora vuelos activos en todo el mundo. Busca por aerolínea, país o código de vuelo y consulta la ubicación directamente desde la tarjeta.
              </p>
            </div>
          </div>

          <!-- Filter Section -->
          <div class="flex items-center justify-center">
            <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-xl">
              <div class="space-y-5">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Buscar</p>
                  <h2 class="text-xl font-bold text-white">Encuentra vuelos</h2>
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-medium text-slate-300" for="searchInput">Busca por callsign, país o aerolínea</label>
                  <input
                    id="searchInput"
                    type="text"
                    placeholder="EG: BA, United, France..."
                    class="w-full rounded-xl border border-white/15 bg-slate-950/50 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 outline-none transition hover:bg-slate-950/70 focus:border-blue-400/50 focus:ring-2 focus:ring-blue-500/20"
                  />
                </div>
                <p class="text-xs leading-6 text-slate-400">
                  Busca en <strong class="text-white">tiempo real</strong> entre todos los vuelos activos del mundo.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Flights Section -->
    <section class="space-y-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">Resultados</p>
          <h2 class="text-2xl font-bold text-white">Vuelos activos</h2>
        </div>
        <div class="inline-flex items-center gap-2 rounded-full bg-white/5 px-4 py-2 text-xs font-medium text-slate-300 border border-white/10">
          <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10.5 1.5H3.75A2.25 2.25 0 001.5 3.75v12.5A2.25 2.25 0 003.75 18.5h12.5a2.25 2.25 0 002.25-2.25V9.5" /></svg>
          Mostrando hasta 20 vuelos
        </div>
      </div>

      {
        apiError && (
          <div class="rounded-xl border border-red-500/30 bg-red-500/10 px-6 py-4 text-sm text-red-200 backdrop-blur-sm">
            Error: Unable to fetch flight data. Please try again later.
          </div>
        )
      }

      {
        !apiError && flights.length === 0 && (
          <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-4 text-sm text-slate-300 backdrop-blur-sm">
            No hay datos de vuelos disponibles en este momento.
          </div>
        )
      }

      {
        !apiError && flights.length > 0 && (
          <div>
            <div class="mb-6 text-sm text-slate-400" id="searchStatus">
              Mostrando 20 vuelos aleatorios del mundo
            </div>
            <script is:inline define:vars={{ allFlightsData: flights, hasError: apiError }}>
              window.__ALL_FLIGHTS__ = allFlightsData || [];
              const statusMsg = hasError ? '❌ API Offline' : `✅ API Online (${allFlightsData?.length || 0} flights)`;
              console.log(`%c${statusMsg}`, 'color: #38bdf8; font-weight: bold; font-size: 12px');
              console.log(`%cBuscaador disponible. ${allFlightsData?.length || 0} vuelos cargados.`, 'color: #10b981; font-size: 12px');
            </script>
            <div
              class="grid gap-5 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
              id="flightGrid"
            >
              {randomFlights.map((flight) => (
                <FlightCard {...flight} />
              ))}
            </div>
          </div>
        )
      }
    </section>

    <script is:inline type="module">
      // Esperar a que el DOM y los datos estén listos
      setTimeout(() => {
        const searchInput = document.querySelector("#searchInput");
        const grid = document.querySelector("#flightGrid");
        const status = document.querySelector("#searchStatus");
        const allFlights = window.__ALL_FLIGHTS__ || [];

        if (!searchInput || !grid || !status) {
          console.error("❌ Elementos del buscador no encontrados");
          return;
        }

        console.log("✅ Buscador inicializado. Vuelos disponibles:", allFlights.length);

        const createFlightCard = (flight) => {
          const card = document.createElement("div");
          card.className =
            "group relative h-full overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-slate-900 to-slate-950 p-5 shadow-lg transition-all duration-300 hover:border-blue-400/50 hover:shadow-blue-500/10 hover:shadow-xl hover:-translate-y-1 backdrop-blur-xl";

          const speedValue = flight.speedKts || 0;
          const altitudeValue = flight.altitude || 0;

          const content = document.createElement("div");
          content.className = "relative space-y-3";

          const header = document.createElement("div");
          header.className = "flex items-start justify-between gap-2";

          const title = document.createElement("h3");
          title.className = "text-lg font-bold text-white leading-tight break-words";
          title.textContent = flight.callsign;

          const badge = document.createElement("span");
          badge.className =
            "inline-flex flex-shrink-0 rounded-lg border border-blue-500/30 bg-blue-500/10 px-2 py-1 text-xs uppercase font-semibold text-blue-300 tracking-wider";
          badge.textContent = flight.country;

          header.appendChild(title);
          header.appendChild(badge);
          content.appendChild(header);

          const regContainer = document.createElement("div");
          regContainer.className = "text-xs text-slate-400";
          regContainer.innerHTML = `<span class="text-slate-500">Reg:</span> ${flight.registration}`;
          content.appendChild(regContainer);

          const statsGrid = document.createElement("div");
          statsGrid.className = "grid grid-cols-2 gap-2 text-xs";

          const createStat = (label, value, icon = "") => {
            const stat = document.createElement("div");
            stat.className = "rounded-lg bg-slate-800/50 p-2 border border-slate-700/50";
            stat.innerHTML = `<p class="text-slate-500 text-xs mb-0.5">${label}</p><p class="font-semibold text-white">${icon} ${value}</p>`;
            return stat;
          };

          statsGrid.appendChild(createStat("Velocidad", `${flight.speedKts} kt`));
          statsGrid.appendChild(createStat("Altitud", `${flight.altitude} ft`));
          statsGrid.appendChild(createStat("Rumbo", `${flight.track}°`));
          statsGrid.appendChild(createStat("V/S", `${flight.trackMovement} ${flight.baroRate} ft/m`));
          statsGrid.appendChild(createStat("Distancia", `${flight.distance} km`));
          statsGrid.appendChild(createStat("Squawk", flight.squawk));
          statsGrid.appendChild(createStat("Categoría", flight.category));

          content.appendChild(statsGrid);
          card.appendChild(content);

          if (flight.lat && flight.lon) {
            const mapContainer = document.createElement("div");
            mapContainer.className =
              "overflow-hidden rounded-xl border border-white/10 h-24 mt-3 relative shadow-lg";

            const iframe = document.createElement("iframe");
            iframe.className = "h-full w-full";
            iframe.src = `https://maps.google.com/maps?q=${flight.lat},${flight.lon}&z=4&output=embed`;
            iframe.loading = "lazy";
            iframe.referrerPolicy = "no-referrer-when-downgrade";
            iframe.title = "Flight location";

            mapContainer.appendChild(iframe);
            card.appendChild(mapContainer);
          }

          if (flight.registration && flight.registration !== "Unknown") {
            const locationLink = document.createElement("button");
            locationLink.type = "button";
            const radarUrl = `https://www.flightradar24.com/${encodeURIComponent(flight.registration)}`;
            locationLink.onclick = () => window.open(radarUrl, '_blank', 'noopener,noreferrer');
            locationLink.className = "inline-flex items-center gap-1 text-xs text-blue-400 hover:text-blue-300 transition mt-3 font-medium cursor-pointer";
            locationLink.innerHTML = `<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg> in Flight Radar`;
            card.appendChild(locationLink);
          }

          return card;
        };

        const renderFlights = (list) => {
          grid.innerHTML = "";

          if (list.length === 0) {
            status.textContent = "No se encontraron vuelos con esa búsqueda.";
            return;
          }

          status.textContent = `Mostrando ${list.length} vuelos encontrados`;

          list.forEach((flight) => {
            grid.appendChild(createFlightCard(flight));
          });
        };

        const search = () => {
          const query = searchInput.value.toLowerCase().trim();

          if (query === "") {
            renderFlights(allFlights.slice(0, 20));
            return;
          }

          const filtered = allFlights.filter((flight) => {
            const callsign = (flight.callsign || "").toLowerCase();
            const country = (flight.country || "").toLowerCase();
            const registration = (flight.registration || "").toLowerCase();
            return callsign.includes(query) || country.includes(query) || registration.includes(query);
          });

          renderFlights(filtered.slice(0, 20));
        };

        searchInput.addEventListener("input", search);
        search();
      }, 100);
    </script>
  </main>
</Layout>
