---
import Layout from '../components/Layout.astro';
import Navbar from '../components/Navbar.astro';
import FlightCard from '../components/FlightCard.astro';
import { fetchFlights } from '../utils/fetchFlights.js';

let flights = [];
let apiError = false;

try {
  flights = await fetchFlights();
} catch (error) {
  console.error('Flight fetch failed:', error.message);
  apiError = true;
}

const allCountries = Array.from(new Set(flights.map((flight) => flight.country).filter(Boolean))).sort();
const countries = ['Todos', ...allCountries];
const selectedCountry = 'Todos';
const displayedFlights = flights.slice(0, 20);
const flightsJson = JSON.stringify(flights).replace(/</g, '\u003c');
const totalCountries = allCountries.length;
---

<Layout>
  <Navbar />

  <div class="mx-auto max-w-6xl px-4 py-10 space-y-10">

    <!-- Hero -->
    <section class="text-center space-y-4 py-6">
      <span class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-sky-500/8 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-sky-300">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-sky-400"></span>
        En vivo
      </span>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        <span class="gradient-text">SkyTrack</span>
      </h1>
      <p class="mx-auto max-w-xl text-base text-slate-400">
        Explora vuelos activos en tiempo real. Filtra por país, consulta velocidad, altitud y ubicación desde cada tarjeta.
      </p>
    </section>

    <!-- Stats row -->
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
      <div class="stat-card rounded-2xl p-5 text-center">
        <p class="text-2xl font-extrabold gradient-text">{flights.length}</p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest text-slate-500">Vuelos cargados</p>
      </div>
      <div class="stat-card rounded-2xl p-5 text-center">
        <p class="text-2xl font-extrabold gradient-text">{totalCountries}</p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest text-slate-500">Países</p>
      </div>
      <div class="stat-card col-span-2 sm:col-span-1 rounded-2xl p-5 text-center">
        <p class="text-2xl font-extrabold gradient-text">{displayedFlights.length}</p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest text-slate-500">Mostrando ahora</p>
      </div>
    </div>

    <!-- Filter + results -->
    <section class="space-y-6">
      <!-- Filter bar -->
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-bold text-white">Vuelos activos</h2>
          <p class="mt-0.5 text-sm text-slate-500" id="searchStatus">Mostrando {displayedFlights.length} vuelos para Todos</p>
        </div>
        <div class="flex items-center gap-3">
          <label class="text-xs font-semibold uppercase tracking-widest text-slate-500 shrink-0" for="countrySelect">País</label>
          <select
            id="countrySelect"
            class="rounded-xl border border-white/10 bg-slate-900/80 px-4 py-2.5 text-sm text-slate-100 outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-500/20"
          >
            {countries.map((country) => (
              <option value={country} selected={country === selectedCountry}>{country}</option>
            ))}
          </select>
        </div>
      </div>

      <!-- Error state -->
      {apiError && (
        <div class="rounded-2xl border border-red-400/20 bg-red-500/10 px-5 py-4 text-sm text-red-300">
          ⚠️ No se pudieron cargar los datos de vuelos. Intenta de nuevo más tarde.
        </div>
      )}

      <!-- Empty state -->
      {!apiError && flights.length === 0 && (
        <div class="rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-sm text-slate-400">
          No hay datos de vuelos disponibles en este momento.
        </div>
      )}

      <!-- Flight grid -->
      {!apiError && flights.length > 0 && (
        <div>
          <div id="flightsData" data-flights={flightsJson} hidden></div>
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" id="flightGrid">
            {displayedFlights.map((flight) => (
              <FlightCard {...flight} />
            ))}
          </div>
        </div>
      )}
    </section>
  </div>

  <script is:inline type="module">
    const flights = JSON.parse(document.getElementById('flightsData')?.dataset.flights || '[]');
    const select = document.querySelector('#countrySelect');
    const grid = document.querySelector('#flightGrid');
    const status = document.querySelector('#searchStatus');

    const renderFlights = (list) => {
      if (!grid || !status) return;
      grid.innerHTML = '';
      const showing = list.slice(0, 20);

      if (showing.length === 0) {
        status.textContent = `No hay vuelos disponibles para ${select?.value}.`;
        return;
      }

      status.textContent = `Mostrando ${showing.length} vuelos para ${select?.value}`;

      showing.forEach((flight) => {
        const card = document.createElement('div');
        card.className = 'flight-card group relative flex flex-col gap-4 rounded-2xl border border-white/10 bg-slate-950/60 p-5 shadow-glow backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-sky-500/30 hover:bg-slate-900/80 hover:shadow-xl';

        const accent = document.createElement('div');
        accent.className = 'absolute inset-x-0 top-0 h-0.5 rounded-t-2xl bg-gradient-to-r from-sky-400 via-indigo-400 to-violet-400 opacity-70 transition duration-300 group-hover:opacity-100';
        card.appendChild(accent);

        const header = document.createElement('div');
        header.className = 'flex items-start justify-between gap-3';

        const headerLeft = document.createElement('div');
        const title = document.createElement('h3');
        title.className = 'text-lg font-bold tracking-tight text-white';
        title.textContent = flight.callsign;
        const badge = document.createElement('span');
        badge.className = 'mt-1 inline-flex items-center gap-1 rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-medium text-slate-300';
        const dot = document.createElement('span');
        dot.className = 'h-1.5 w-1.5 rounded-full bg-emerald-400';
        badge.appendChild(dot);
        badge.appendChild(document.createTextNode(flight.country));
        headerLeft.appendChild(title);
        headerLeft.appendChild(badge);

        const icon = document.createElement('div');
        icon.className = 'flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-sky-500/10 text-sky-400 text-sm';
        icon.textContent = '✈';

        header.appendChild(headerLeft);
        header.appendChild(icon);
        card.appendChild(header);

        const metrics = document.createElement('div');
        metrics.className = 'grid grid-cols-2 gap-2';

        const speedChip = document.createElement('div');
        speedChip.className = 'metric-chip';
        const speedLabel = document.createElement('p');
        speedLabel.className = 'text-[10px] font-semibold uppercase tracking-widest text-amber-400/80';
        speedLabel.textContent = 'Velocidad';
        const speedVal = document.createElement('p');
        speedVal.className = 'mt-0.5 text-sm font-bold text-amber-300';
        speedVal.textContent = `${flight.speedKts} kt`;
        const speedSub = document.createElement('p');
        speedSub.className = 'text-xs text-slate-500';
        speedSub.textContent = `${flight.speedKmh} km/h`;
        speedChip.appendChild(speedLabel);
        speedChip.appendChild(speedVal);
        speedChip.appendChild(speedSub);

        const altChip = document.createElement('div');
        altChip.className = 'metric-chip';
        const altM = Math.round(flight.altitude * 0.3048);
        const altLabel = document.createElement('p');
        altLabel.className = 'text-[10px] font-semibold uppercase tracking-widest text-sky-400/80';
        altLabel.textContent = 'Altitud';
        const altVal = document.createElement('p');
        altVal.className = 'mt-0.5 text-sm font-bold text-sky-300';
        altVal.textContent = `${flight.altitude} ft`;
        const altSub = document.createElement('p');
        altSub.className = 'text-xs text-slate-500';
        altSub.textContent = `${altM} m`;
        altChip.appendChild(altLabel);
        altChip.appendChild(altVal);
        altChip.appendChild(altSub);

        metrics.appendChild(speedChip);
        metrics.appendChild(altChip);
        card.appendChild(metrics);

        if (flight.lat && flight.lon) {
          const mapContainer = document.createElement('div');
          mapContainer.className = 'overflow-hidden rounded-xl border border-white/8 h-[160px]';
          const iframe = document.createElement('iframe');
          iframe.className = 'h-full w-full';
          iframe.src = `https://maps.google.com/maps?q=${flight.lat},${flight.lon}&z=4&output=embed`;
          iframe.loading = 'lazy';
          iframe.referrerPolicy = 'no-referrer-when-downgrade';
          iframe.title = 'Flight location';
          mapContainer.appendChild(iframe);
          card.appendChild(mapContainer);

          const link = document.createElement('a');
          link.className = 'flex items-center gap-1.5 text-xs font-medium text-sky-400 transition hover:text-sky-300';
          link.href = `https://www.google.com/maps/search/?api=1&query=${flight.lat},${flight.lon}`;
          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          link.innerHTML = `<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>Abrir en Google Maps`;
          card.appendChild(link);
        } else {
          const noLoc = document.createElement('p');
          noLoc.className = 'text-xs text-slate-500';
          noLoc.textContent = 'Ubicación no disponible';
          card.appendChild(noLoc);
        }

        grid.appendChild(card);
      });
    };

    if (select) {
      const update = () => {
        const country = select.value;
        const filtered = country === 'Todos' ? flights : flights.filter((flight) => flight.country === country);
        renderFlights(filtered);
      };
      select.addEventListener('change', update);
      update();
    }
  </script>
</Layout>
