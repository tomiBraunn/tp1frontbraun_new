---
const { callsign, country, speedKts, speedKmh, altitude, lat, lon } = Astro.props;
const hasLocation = lat && lon;
const mapsUrl = hasLocation ? `https://www.google.com/maps/search/?api=1&query=${lat},${lon}` : null;
---
<div class="flight-card grid gap-4 rounded-[26px] border border-white/10 bg-white/5 p-5 shadow-glow backdrop-blur-xl transition duration-300 ease-out hover:-translate-y-1 hover:shadow-2xl" data-callsign={callsign.toLowerCase()} data-country={country.toLowerCase()} data-lat={lat} data-lon={lon}>
  <div class="space-y-2">
    <h3 class="text-lg font-semibold tracking-tight text-white">{callsign}</h3>
    <p class="text-slate-400 text-sm">Country: {country}</p>
  </div>

  <div class="grid gap-2 text-sm text-slate-300">
    <p>Speed: <span class="text-sky-300 font-semibold">{speedKts} kt</span> <span class="text-slate-400">({speedKmh} km/h)</span></p>
    <p>Altitude: <span class="text-slate-100">{altitude} ft</span></p>
  </div>

  {hasLocation ? (
    <>
      <div class="overflow-hidden rounded-2xl border border-white/10 h-[180px]">
        <iframe
          class="h-full w-full"
          src={`https://maps.google.com/maps?q=${lat},${lon}&z=4&output=embed`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Flight location"
        ></iframe>
      </div>
      <p class="text-sm text-slate-300">Location: <a class="text-sky-300 transition hover:text-sky-200" href={mapsUrl} target="_blank" rel="noopener noreferrer">Open in Google Maps</a></p>
    </>
  ) : (
    <p class="text-sm text-slate-300">Location: Unknown</p>
  )}
</div>